# Copy to .env and fill in the values.

# ---------- GLM (Zhipu AI) ----------
# OpenAI-compatible endpoint. Get your API key from https://open.bigmodel.cn
GLM_API_KEY=
# Default model — override per request if you want a cheaper/faster one.
GLM_MODEL=glm-4.6
# Usually no need to change this unless you self-host a proxy.
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ---------- Main agent HTTP API ----------
BIND_HOST=0.0.0.0
BIND_PORT=9000
# Optional bearer token required on /chat and /mcp/status. Leave empty
# to keep the API open (fine if the network is trusted).
# Generate one with: openssl rand -hex 32
API_KEY=

# ---------- MCP registry ----------
# Path (relative to workdir) to the YAML listing the MCP servers the
# agent should connect to at startup.
MCP_CONFIG_PATH=mcp_servers.yaml

# ---------- MCP server credentials ----------
# These env vars are referenced by mcp_servers.yaml via `${VAR}` syntax.
# Set them here so secrets live in .env and not in version control.

# Shared bearer token. Set the same value here and on every MCP app
# (jellyfin-mcp, memory-mcp, ...). Leave empty to skip auth across the
# whole homelab (acceptable on a trusted LAN). Rotate by updating every
# app at once.
MCP_HTTP_TOKEN=

# Per-MCP URLs. Override only if you run Rotom outside dokploy-network
# (e.g. locally on the Mac) — then point these at the host-published
# ports, e.g. http://192.168.1.251:8765/mcp and :8766/mcp.
JELLYFIN_MCP_URL=http://jellyfin-mcp:8000/mcp
MEMORY_MCP_URL=http://memory-mcp:8000/mcp
